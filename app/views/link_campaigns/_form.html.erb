<%= form_with(model: link_campaign, class: "contents") do |form| %>
  <% if link_campaign.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(link_campaign.errors.count, "error") %> prohibited this link_campaign from being saved:</h2>

      <ul class="list-disc ml-6">
        <% link_campaign.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :link_id %>
    <%= form.text_field :link_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": link_campaign.errors[:link_id].none?, "border-red-400 focus:outline-red-600": link_campaign.errors[:link_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :campaign_id %>
    <%= form.text_field :campaign_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": link_campaign.errors[:campaign_id].none?, "border-red-400 focus:outline-red-600": link_campaign.errors[:campaign_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
