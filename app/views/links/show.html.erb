<% content_for :title, "Showing link" %>

<div class="mx-auto w-full max-w-7xl space-y-8">
  <header class="rounded-2xl border border-gray-200 bg-gradient-to-r from-slate-50 via-white to-sky-50 p-6 shadow-sm sm:p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Link management</p>
    <div class="mt-3 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">Showing link</h1>
        <p class="mt-2 text-sm text-slate-600">Review destination details, share the short URL, and inspect recent traffic.</p>
      </div>
      <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">
        Active
      </span>
    </div>
  </header>

  <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
    <section class="xl:col-span-2 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-7">
      <div class="border-b border-gray-100 pb-5">
        <h2 class="text-lg font-semibold text-slate-900">Link details</h2>
        <p class="mt-1 text-sm text-slate-500">Primary configuration and destination metadata.</p>
      </div>

      <div class="mt-6">
        <%= render @link %>
      </div>

      <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-4 sm:p-5">
        <p class="text-xs font-medium uppercase tracking-[0.1em] text-slate-500">Public short URL</p>
        <%= link_to short_url(@link.slug), short_url(@link.slug), class: "mt-2 inline-flex break-all text-sm font-semibold text-sky-700 hover:text-sky-800 hover:underline", target: "_blank", rel: "noopener" %>
      </div>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-7">
      <h2 class="text-lg font-semibold text-slate-900">QR code</h2>
      <p class="mt-1 text-sm text-slate-500">Scan to open the short URL instantly.</p>
      <div class="mt-5 inline-flex rounded-xl border border-gray-200 bg-white p-3 shadow-sm">
        <%== qr_svg_for(short_url(@link.slug), module_size: 5) %>
      </div>
      <p class="mt-3 text-xs text-slate-500">Scans to /<%= @link.slug %></p>
    </section>
  </div>

  <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-7">
    <div class="flex flex-wrap items-end justify-between gap-3 border-b border-gray-100 pb-4">
      <div>
        <h2 class="text-lg font-semibold text-slate-900">Recent visits</h2>
        <p class="mt-1 text-sm text-slate-500">Latest traffic and user agent information for this short link.</p>
      </div>
      <% if @recent_visits.any? %>
        <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
          <%= @recent_visits.size %> on this page
        </span>
      <% end %>
    </div>

    <% if @recent_visits.any? %>
      <div class="mt-5 overflow-x-auto rounded-xl border border-gray-100">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
            <tr>
              <th class="px-4 py-3">Visited at</th>
              <th class="px-4 py-3">IP</th>
              <th class="px-4 py-3">Browser</th>
              <th class="px-4 py-3">OS</th>
              <th class="px-4 py-3">Device</th>
              <th class="px-4 py-3">Bot</th>
              <th class="px-4 py-3">View</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white text-slate-700">
            <% @recent_visits.each do |visit| %>
              <tr class="hover:bg-slate-50/70">
                <td class="whitespace-nowrap px-4 py-3"><%= format_visit_time(visit.visited_at) %></td>
                <td class="whitespace-nowrap px-4 py-3"><%= visit.ip_address %></td>
                <td class="px-4 py-3"><%= visit.browser %></td>
                <td class="px-4 py-3"><%= visit.os %></td>
                <td class="px-4 py-3"><%= visit.device_type %></td>
                <td class="px-4 py-3">
                  <% if visit.bot? %>
                    <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-700">Yes</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700">No</span>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-4 py-3">
                  <%= link_to "Details", visit_path(visit), class: "font-medium text-sky-700 hover:text-sky-800 hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy_visits.pages > 1 %>
        <div class="mt-5">
          <%== @pagy_visits.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="mt-5 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-6 text-center">
        <p class="text-sm font-medium text-slate-700">No visits recorded yet</p>
        <p class="mt-1 text-sm text-slate-500">Traffic analytics will appear here once this link receives visits.</p>
      </div>
    <% end %>
  </section>

  <div class="flex flex-wrap gap-3 border-t border-gray-200 pt-2">
    <%= link_to "Edit this link", edit_link_path(@link), class: "inline-flex w-full items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 sm:w-auto" %>
    <%= link_to "Back to links", links_path, class: "inline-flex w-full items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 sm:w-auto" %>
    <%= button_to "Destroy this link", @link, method: :delete, form_class: "w-full sm:w-auto", class: "inline-flex w-full items-center justify-center rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-red-500", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
