<% content_for :title, "Visits" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Visits</h1>
  </div>

  <%= form_with url: visits_path, method: :get, class: "mt-4 mb-6 grid grid-cols-1 md:grid-cols-5 gap-2" do |form| %>
    <%= form.collection_select :link_id, @links_for_filter, :id, :name, { include_blank: "All links", selected: @filters[:link_id] }, class: "rounded-md border border-gray-300 px-3 py-2" %>
    <%= form.date_field :start_date, value: @filters[:start_date], class: "rounded-md border border-gray-300 px-3 py-2" %>
    <%= form.date_field :end_date, value: @filters[:end_date], class: "rounded-md border border-gray-300 px-3 py-2" %>
    <%= form.select :bot, [["All traffic", ""], ["Bots", "true"], ["Humans", "false"]], { selected: @filters[:bot] }, class: "rounded-md border border-gray-300 px-3 py-2" %>
    <%= form.submit "Filter", class: "rounded-md px-3.5 py-2.5 bg-gray-900 text-white font-medium" %>
  <% end %>

  <div id="visits" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @visits.any? %>
      <% @visits.each do |visit| %>
        <div class="flex flex-col sm:flex-row justify-between items-start pb-5 sm:pb-0">
          <%= render visit %>
          <div class="w-full sm:w-auto mt-3 sm:mt-0">
            <%= link_to "Show", visit, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No visits found.</p>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
